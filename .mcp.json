{
  "mcpServers": {
    "bravesearch": {
      "type": "http",
      "url": "https://brave-search-mcp.lan.${EXTERNAL_DOMAIN}/mcp",
      "headers": {
        "X-API-KEY": "${BRAVE_SEARCH_MCP_API_KEY}"
      }
    },
    "github": {
      "type": "http",
      "url": "https://github-mcp.lan.${EXTERNAL_DOMAIN}/mcp",
      "headers": {
        "X-API-KEY": "${GITHUB_MCP_API_KEY}"
      }
    }
  }
}
