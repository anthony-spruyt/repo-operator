{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    // ============ Supply-chain default ============
    {
      description: "Default minimum release age for supply-chain safety (overridden per-package below)",
      matchUpdateTypes: ["major", "minor", "patch"],
      minimumReleaseAge: "7 days"
    },

    // ============ High-frequency packages ============
    {
      description: "Limit renovate CLI updates to weekly (releases multiple times daily)",
      matchPackageNames: ["renovate"],
      matchDatasources: ["npm", "docker"],
      schedule: ["before 9am on monday"],
      labels: ["renovate/renovate-cli"]
    },
    {
      description: "Limit GitHub Actions digest updates to weekly and group them",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["digest"],
      schedule: ["before 9am on monday"],
      groupName: "github-actions-digest",
      group: {
        commitMessageTopic: "GitHub Actions digest updates"
      }
    },

    // ============ Devcontainer base image (managed via xfg sync) ============
    {
      description: "Disable devcontainer updates in all repos except repo-operator (xfg syncs the devcontainer config)",
      matchManagers: ["devcontainer"],
      matchRepositories: ["!/anthony-spruyt/repo-operator/"],
      enabled: false
    },

    // ============ Disable self-referencing workflow updates ============
    {
      description: "Disable updates for self-hosted reusable workflows (intentionally track @main)",
      matchPackageNames: ["anthony-spruyt/repo-operator"],
      matchManagers: ["github-actions"],
      enabled: false
    },

    // ============ Repo-specific rules ============
    {
      description: "Coder uses two-channel releases (mainline/stable); 30-day delay avoids adopting unproven mainline versions",
      matchRepositories: ["anthony-spruyt/spruyt-labs"],
      matchPackageNames: ["coder"],
      matchDatasources: ["helm"],
      minimumReleaseAge: "30 days"
    },
    {
      description: "Weekly batch for all non-major updates in container-images (excludes named groups)",
      matchRepositories: ["anthony-spruyt/container-images"],
      matchUpdateTypes: ["minor", "patch", "digest", "pin", "pinDigest"],
      matchPackageNames: [
        "!kubernetes",
        "!kubernetes/kubernetes",
        "!siderolabs/talos",
        "!ghcr.io/siderolabs/installer",
        "!ghcr.io/siderolabs/kubelet",
        "!bitnami/kubectl",
        "!public.ecr.aws/bitnami/kubectl",
        "!alpine/k8s",
        "!cilium",
        "!cilium/cilium-cli",
        "!cilium/hubble",
        "!quay.io/cilium/cilium",
        "!quay.io/cilium/operator-generic"
      ],
      schedule: ["before 9am on monday"],
      groupName: "weekly-dependencies",
      group: {
        commitMessageTopic: "weekly dependency updates"
      }
    },

    // ============ Docker/OCI ============
    {
      matchDatasources: ["docker", "oci"],
      enabled: true,
      commitMessageTopic: "container image {{depName}}",
      commitMessageExtra: "to {{#if isSingleVersion}}v{{{newVersion}}}{{else}}{{{newValue}}}{{/if}}",
      pinDigests: true
    },
    {
      matchDatasources: ["docker", "oci"],
      matchUpdateTypes: ["major"],
      labels: ["renovate/image", "dep/major"]
    },
    {
      matchDatasources: ["docker", "oci"],
      matchUpdateTypes: ["minor"],
      labels: ["renovate/image", "dep/minor"]
    },
    {
      matchDatasources: ["docker", "oci"],
      matchUpdateTypes: ["patch"],
      labels: ["renovate/image", "dep/patch"]
    },

    // ============ Helm ============
    {
      matchDatasources: ["helm"],
      separateMinorPatch: true,
      ignoreDeprecated: true
    },
    {
      matchDatasources: ["helm"],
      matchUpdateTypes: ["major"],
      labels: ["renovate/helm", "dep/major"]
    },
    {
      matchDatasources: ["helm"],
      matchUpdateTypes: ["minor"],
      labels: ["renovate/helm", "dep/minor"]
    },
    {
      matchDatasources: ["helm"],
      matchUpdateTypes: ["patch"],
      labels: ["renovate/helm", "dep/patch"]
    },

    // ============ Dockerfile ARG dedup ============
    {
      description: "Disable dockerfile manager for golang in spruyt-labs (ARG interpolation breaks updates; custom.regex manager handles these via annotations)",
      matchRepositories: ["anthony-spruyt/spruyt-labs"],
      matchManagers: ["dockerfile"],
      matchPackageNames: ["golang"],
      enabled: false
    },

    // ============ Managers ============
    {
      matchManagers: ["github-actions"],
      addLabels: ["renovate/github-actions"]
    },
    {
      matchManagers: ["terraform"],
      addLabels: ["renovate/terraform"],
      separateMinorPatch: true
    },
    {
      matchManagers: ["devcontainer"],
      addLabels: ["renovate/devcontainer"]
    },
    {
      matchManagers: ["npm"],
      addLabels: ["renovate/npm"]
    },
    {
      matchManagers: ["pip_requirements"],
      addLabels: ["renovate/python"]
    },
    {
      matchManagers: ["pre-commit"],
      addLabels: ["renovate/pre-commit"]
    },
    {
      matchManagers: ["flux"],
      addLabels: ["renovate/flux"]
    },
    {
      description: "Disable digest pinning for Flux manager on OCI sources (Flux manager cannot insert digest field into OCIRepository spec/ref)",
      matchManagers: ["flux"],
      matchDatasources: ["docker", "oci"],
      pinDigests: false
    },
    {
      matchManagers: ["kubernetes"],
      addLabels: ["renovate/kubernetes"]
    },
    {
      matchManagers: ["helm-values"],
      addLabels: ["renovate/helm-values"]
    },

    // ============ Custom regex ============
    {
      description: "Disable digest pinning for all custom regex managers (regex replacement cannot insert new digests, only update existing ones; built-in managers handle initial pinning)",
      matchManagers: ["custom.regex"],
      addLabels: ["renovate/script"],
      pinDigests: false
    },
    {
      matchManagers: ["custom.regex"],
      matchFileNames: ["**/flavor.yaml"],
      addLabels: ["renovate/megalinter-flavor"]
    },
    {
      matchManagers: ["custom.regex"],
      matchFileNames: ["**/metadata.yaml"],
      addLabels: ["renovate/upstream"]
    },
    {
      matchManagers: ["custom.regex"],
      matchFileNames: [".taskfiles/**"],
      addLabels: ["renovate/taskfile"]
    },
    {
      matchManagers: ["custom.regex"],
      matchFileNames: ["talos/**"],
      addLabels: ["renovate/talos"]
    }
  ]
}
