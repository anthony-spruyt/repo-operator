# GitHub rate-limits unauthenticated requests (429 Too Many Requests)
https://github.com/.*
https://raw.githubusercontent.com/.*

# GitHub API URLs require authentication and can't be validated
https://api.github.com/.*

# Localhost URLs are not reachable in CI/lint environments
http://localhost.*
https://localhost.*
http://127\.0\.0\.1.*
https://127\.0\.0\.1.*

# LAN server URLs use private .lan domains with shell variable substitution
.*\.lan/.*
